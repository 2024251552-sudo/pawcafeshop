// PawCafeReceipt.java - Receipt Page (Simplified & Fixed)
import javax.swing.*;
import javax.swing.border.EmptyBorder;
import java.awt.*;
import java.text.SimpleDateFormat;
import java.util.ArrayList;
import java.util.Date;

public class PawCafeReceipt extends JFrame {
    private String cashierName;
    private ArrayList<OrderItem> orderItems;
    private double total, discount, finalTotal;
    private int totalItems;
    private String paymentMethod;
    
    public PawCafeReceipt(String cashierName, ArrayList<OrderItem> orderItems, 
                         double total, double discount, double finalTotal, 
                         int totalItems, String paymentMethod) {
        this.cashierName = cashierName;
        this.orderItems = orderItems;
        this.total = total;
        this.discount = discount;
        this.finalTotal = finalTotal;
        this.totalItems = totalItems;
        this.paymentMethod = paymentMethod;
        
        setTitle("Paw Café - Receipt");
        setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        setSize(650, 700);
        setLocationRelativeTo(null);
        setResizable(false);
        
        try {
            UIManager.setLookAndFeel(UIManager.getSystemLookAndFeelClassName());
        } catch (Exception e) {
            e.printStackTrace();
        }
        
        initializeUI();
    }
    
    private void initializeUI() {
        // Main Panel
        JPanel mainPanel = new JPanel(new BorderLayout(0, 0));
        mainPanel.setBackground(new Color(255, 248, 240));
        
        // ========================================
        // NAVIGATION BAR
        // ========================================
        JPanel navBar = new JPanel(new BorderLayout());
        navBar.setBackground(new Color(139, 69, 19));
        navBar.setBorder(new EmptyBorder(10, 20, 10, 20));
        navBar.setPreferredSize(new Dimension(getWidth(), 55));
        
        JLabel logoLabel = new JLabel("🐾 Paw Café");
        logoLabel.setFont(new Font("Serif", Font.BOLD, 22));
        logoLabel.setForeground(Color.WHITE);
        navBar.add(logoLabel, BorderLayout.WEST);
        
        JPanel rightPanel = new JPanel(new FlowLayout(FlowLayout.RIGHT, 10, 0));
        rightPanel.setOpaque(false);
        
        JLabel userLabel = new JLabel("👤 " + cashierName);
        userLabel.setFont(new Font("SansSerif", Font.PLAIN, 13));
        userLabel.setForeground(Color.WHITE);
        
        JButton homeBtn = new JButton("Home");
        homeBtn.setFont(new Font("SansSerif", Font.BOLD, 12));
        homeBtn.setBackground(new Color(52, 152, 219));
        homeBtn.setForeground(Color.WHITE);
        homeBtn.setFocusPainted(false);
        homeBtn.setBorder(BorderFactory.createEmptyBorder(6, 15, 6, 15));
        homeBtn.setCursor(new Cursor(Cursor.HAND_CURSOR));
        homeBtn.addActionListener(e -> {
            int confirm = JOptionPane.showConfirmDialog(this,
                "Your current order will be lost. Continue?",
                "Confirm",
                JOptionPane.YES_NO_OPTION);
            if (confirm == JOptionPane.YES_OPTION) {
                dispose();
                new PawCafeHome(cashierName).setVisible(true);
            }
        });
        
        JButton logoutBtn = new JButton("Logout");
        logoutBtn.setFont(new Font("SansSerif", Font.BOLD, 12));
        logoutBtn.setBackground(new Color(200, 50, 50));
        logoutBtn.setForeground(Color.WHITE);
        logoutBtn.setFocusPainted(false);
        logoutBtn.setBorder(BorderFactory.createEmptyBorder(6, 15, 6, 15));
        logoutBtn.setCursor(new Cursor(Cursor.HAND_CURSOR));
        logoutBtn.addActionListener(e -> {
            int confirm = JOptionPane.showConfirmDialog(this,
                "Are you sure you want to logout?",
                "Logout Confirmation",
                JOptionPane.YES_NO_OPTION);
            if (confirm == JOptionPane.YES_OPTION) {
                dispose();
                new PawCafeLogin().setVisible(true);
            }
        });
        
        rightPanel.add(userLabel);
        rightPanel.add(homeBtn);
        rightPanel.add(logoutBtn);
        navBar.add(rightPanel, BorderLayout.EAST);
        
        mainPanel.add(navBar, BorderLayout.NORTH);
        
        // ========================================
        // CONTENT PANEL
        // ========================================
        JPanel contentPanel = new JPanel(new BorderLayout(0, 0));
        contentPanel.setBorder(new EmptyBorder(15, 20, 15, 20));
        contentPanel.setBackground(new Color(255, 248, 240));
        
        // ========================================
        // RECEIPT PANEL - Using GridBagLayout for better control
        // ========================================
        JPanel receiptPanel = new JPanel(new GridBagLayout());
        receiptPanel.setBackground(Color.WHITE);
        receiptPanel.setBorder(BorderFactory.createCompoundBorder(
            BorderFactory.createLineBorder(new Color(180, 150, 120), 2),
            BorderFactory.createEmptyBorder(20, 25, 20, 25)
        ));
        receiptPanel.setPreferredSize(new Dimension(500, 480));
        
        GridBagConstraints c = new GridBagConstraints();
        c.insets = new Insets(4, 5, 4, 5);
        c.fill = GridBagConstraints.HORIZONTAL;
        c.gridx = 0;
        c.gridwidth = 2;
        
        // Row 0: Cafe Name
        c.gridy = 0;
        JLabel cafeName = new JLabel("🐾 Paw Café");
        cafeName.setFont(new Font("Serif", Font.BOLD, 28));
        cafeName.setForeground(new Color(139, 69, 19));
        cafeName.setHorizontalAlignment(SwingConstants.CENTER);
        receiptPanel.add(cafeName, c);
        
        // Row 1: Receipt Title
        c.gridy = 1;
        JLabel receiptTitle = new JLabel("RECEIPT");
        receiptTitle.setFont(new Font("SansSerif", Font.BOLD, 18));
        receiptTitle.setForeground(new Color(80, 50, 30));
        receiptTitle.setHorizontalAlignment(SwingConstants.CENTER);
        receiptPanel.add(receiptTitle, c);
        
        // Row 2: Separator
        c.gridy = 2;
        c.insets = new Insets(8, 5, 8, 5);
        JSeparator sep1 = new JSeparator();
        receiptPanel.add(sep1, c);
        
        // Row 3: Cashier Info
        c.gridy = 3;
        c.insets = new Insets(2, 5, 2, 5);
        SimpleDateFormat dateFormat = new SimpleDateFormat("dd/MM/yyyy");
        SimpleDateFormat timeFormat = new SimpleDateFormat("hh:mm a");
        Date now = new Date();
        
        JPanel infoPanel = new JPanel(new GridLayout(3, 1, 0, 2));
        infoPanel.setOpaque(false);
        JLabel cashierInfo = new JLabel("Cashier Name: " + cashierName);
        cashierInfo.setFont(new Font("Monospaced", Font.PLAIN, 13));
        cashierInfo.setHorizontalAlignment(SwingConstants.CENTER);
        JLabel dateInfo = new JLabel("Date: " + dateFormat.format(now));
        dateInfo.setFont(new Font("Monospaced", Font.PLAIN, 13));
        dateInfo.setHorizontalAlignment(SwingConstants.CENTER);
        JLabel timeInfo = new JLabel("Time: " + timeFormat.format(now));
        timeInfo.setFont(new Font("Monospaced", Font.PLAIN, 13));
        timeInfo.setHorizontalAlignment(SwingConstants.CENTER);
        infoPanel.add(cashierInfo);
        infoPanel.add(dateInfo);
        infoPanel.add(timeInfo);
        receiptPanel.add(infoPanel, c);
        
        // Row 4: Separator
        c.gridy = 4;
        c.insets = new Insets(8, 5, 8, 5);
        JSeparator sep2 = new JSeparator();
        receiptPanel.add(sep2, c);
        
        // Row 5: Table Header
        c.gridy = 5;
        c.insets = new Insets(2, 5, 2, 5);
        JPanel headerPanel = new JPanel(new BorderLayout(5, 0));
        headerPanel.setOpaque(false);
        JLabel itemHeader = new JLabel("Item");
        itemHeader.setFont(new Font("Monospaced", Font.BOLD, 12));
        JPanel headerRight = new JPanel(new GridLayout(1, 3, 10, 0));
        headerRight.setOpaque(false);
        headerRight.add(new JLabel("Qty", SwingConstants.CENTER));
        headerRight.add(new JLabel("Price", SwingConstants.CENTER));
        headerRight.add(new JLabel("Subtotal", SwingConstants.RIGHT));
        for (Component comp : headerRight.getComponents()) {
            comp.setFont(new Font("Monospaced", Font.BOLD, 12));
        }
        headerPanel.add(itemHeader, BorderLayout.WEST);
        headerPanel.add(headerRight, BorderLayout.EAST);
        receiptPanel.add(headerPanel, c);
        
        // Row 6: Separator
        c.gridy = 6;
        c.insets = new Insets(2, 5, 2, 5);
        JSeparator sep3 = new JSeparator();
        receiptPanel.add(sep3, c);
        
        // Row 7-12: Items
        int row = 7;
        for (OrderItem item : orderItems) {
            c.gridy = row++;
            c.insets = new Insets(1, 5, 1, 5);
            JPanel itemPanel = new JPanel(new BorderLayout(5, 0));
            itemPanel.setOpaque(false);
            JLabel nameLabel = new JLabel(item.getName());
            nameLabel.setFont(new Font("Monospaced", Font.PLAIN, 11));
            JPanel itemRight = new JPanel(new GridLayout(1, 3, 10, 0));
            itemRight.setOpaque(false);
            itemRight.add(new JLabel(String.valueOf(item.getQuantity()), SwingConstants.CENTER));
            itemRight.add(new JLabel(String.format("RM %.2f", item.getPrice()), SwingConstants.CENTER));
            itemRight.add(new JLabel(String.format("RM %.2f", item.getSubtotal()), SwingConstants.RIGHT));
            for (Component comp : itemRight.getComponents()) {
                comp.setFont(new Font("Monospaced", Font.PLAIN, 11));
            }
            itemPanel.add(nameLabel, BorderLayout.WEST);
            itemPanel.add(itemRight, BorderLayout.EAST);
            receiptPanel.add(itemPanel, c);
        }
        
        // Row: Separator after items
        c.gridy = row++;
        c.insets = new Insets(6, 5, 6, 5);
        JSeparator sep4 = new JSeparator();
        receiptPanel.add(sep4, c);
        
        // Row: Totals
        c.gridy = row++;
        c.insets = new Insets(1, 5, 1, 5);
        JPanel totalsPanel = new JPanel(new GridLayout(discount > 0 ? 3 : 2, 1, 0, 1));
        totalsPanel.setOpaque(false);
        
        JPanel totalItemsRow = new JPanel(new BorderLayout());
        totalItemsRow.setOpaque(false);
        totalItemsRow.add(new JLabel("Total Items:"), BorderLayout.WEST);
        JLabel totalItemsVal = new JLabel(String.valueOf(totalItems), SwingConstants.RIGHT);
        totalItemsVal.setFont(new Font("Monospaced", Font.PLAIN, 12));
        totalItemsRow.add(totalItemsVal, BorderLayout.EAST);
        totalsPanel.add(totalItemsRow);
        
        JPanel totalRow = new JPanel(new BorderLayout());
        totalRow.setOpaque(false);
        totalRow.add(new JLabel("Total (RM):"), BorderLayout.WEST);
        JLabel totalVal = new JLabel(String.format("RM %.2f", total), SwingConstants.RIGHT);
        totalVal.setFont(new Font("Monospaced", Font.PLAIN, 12));
        totalRow.add(totalVal, BorderLayout.EAST);
        totalsPanel.add(totalRow);
        
        if (discount > 0) {
            JPanel discountRow = new JPanel(new BorderLayout());
            discountRow.setOpaque(false);
            JLabel discLabel = new JLabel("Discount (10%):");
            discLabel.setForeground(new Color(200, 50, 50));
            discountRow.add(discLabel, BorderLayout.WEST);
            JLabel discVal = new JLabel(String.format("-RM %.2f", discount), SwingConstants.RIGHT);
            discVal.setForeground(new Color(200, 50, 50));
            discVal.setFont(new Font("Monospaced", Font.PLAIN, 12));
            discountRow.add(discVal, BorderLayout.EAST);
            totalsPanel.add(discountRow);
        }
        
        for (Component comp : totalsPanel.getComponents()) {
            if (comp instanceof JPanel) {
                for (Component sub : ((JPanel) comp).getComponents()) {
                    if (sub instanceof JLabel) {
                        ((JLabel) sub).setFont(new Font("Monospaced", Font.PLAIN, 12));
                    }
                }
            }
        }
        receiptPanel.add(totalsPanel, c);
        
        // Row: Separator
        c.gridy = row++;
        c.insets = new Insets(6, 5, 6, 5);
        JSeparator sep5 = new JSeparator();
        receiptPanel.add(sep5, c);
        
        // Row: Final Total
        c.gridy = row++;
        c.insets = new Insets(2, 5, 2, 5);
        JLabel finalLabel = new JLabel("FINAL TOTAL: " + String.format("RM %.2f", finalTotal));
        finalLabel.setFont(new Font("Monospaced", Font.BOLD, 20));
        finalLabel.setForeground(new Color(139, 69, 19));
        finalLabel.setHorizontalAlignment(SwingConstants.CENTER);
        receiptPanel.add(finalLabel, c);
        
        // Row: Separator
        c.gridy = row++;
        c.insets = new Insets(6, 5, 6, 5);
        JSeparator sep6 = new JSeparator();
        receiptPanel.add(sep6, c);
        
        // Row: Payment Method
        c.gridy = row++;
        c.insets = new Insets(2, 5, 2, 5);
        JLabel paymentLabel = new JLabel("Payment Method: " + paymentMethod);
        paymentLabel.setFont(new Font("Monospaced", Font.BOLD, 13));
        paymentLabel.setForeground(new Color(80, 50, 30));
        paymentLabel.setHorizontalAlignment(SwingConstants.CENTER);
        receiptPanel.add(paymentLabel, c);
        
        // Row: Footer
        c.gridy = row++;
        c.insets = new Insets(8, 5, 2, 5);
        JLabel footer = new JLabel("\"Simple Orders, Happy Hearts at Paw Café.\"");
        footer.setFont(new Font("SansSerif", Font.ITALIC, 10));
        footer.setForeground(new Color(101, 67, 33));
        footer.setHorizontalAlignment(SwingConstants.CENTER);
        receiptPanel.add(footer, c);
        
        // Center the receipt panel
        JPanel centerWrapper = new JPanel(new GridBagLayout());
        centerWrapper.setOpaque(false);
        centerWrapper.add(receiptPanel);
        
        contentPanel.add(centerWrapper, BorderLayout.CENTER);
        
        // ========================================
        // BOTTOM BUTTONS
        // ========================================
        JPanel bottomBtnPanel = new JPanel(new FlowLayout(FlowLayout.CENTER, 20, 10));
        bottomBtnPanel.setOpaque(false);
        
        JButton backBtn = new JButton("🔙 Back to Calculation");
        backBtn.setFont(new Font("SansSerif", Font.BOLD, 13));
        backBtn.setBackground(new Color(180, 150, 120));
        backBtn.setForeground(Color.WHITE);
        backBtn.setFocusPainted(false);
        backBtn.setBorder(BorderFactory.createEmptyBorder(8, 25, 8, 25));
        backBtn.setCursor(new Cursor(Cursor.HAND_CURSOR));
        backBtn.addActionListener(e -> {
            dispose();
            new PawCafeCalculate(cashierName, orderItems, paymentMethod).setVisible(true);
        });
        
        JButton saveBtn = new JButton("💾 SAVE TO FILE");
        saveBtn.setFont(new Font("SansSerif", Font.BOLD, 13));
        saveBtn.setBackground(new Color(139, 69, 19));
        saveBtn.setForeground(Color.WHITE);
        saveBtn.setFocusPainted(false);
        saveBtn.setBorder(BorderFactory.createEmptyBorder(8, 35, 8, 35));
        saveBtn.setCursor(new Cursor(Cursor.HAND_CURSOR));
        saveBtn.addActionListener(e -> {
            dispose();
            new PawCafeSave(cashierName, orderItems, total, discount, finalTotal, totalItems, paymentMethod).setVisible(true);
        });
        
        bottomBtnPanel.add(backBtn);
        bottomBtnPanel.add(saveBtn);
        
        contentPanel.add(bottomBtnPanel, BorderLayout.SOUTH);
        
        mainPanel.add(contentPanel, BorderLayout.CENTER);
        add(mainPanel);
    }
}
